    /* ---- Hero grid motif and reveal: must be global, the spans are
       created at runtime and never receive Astro's scope hash ---- */
    :global(.gridmotif) {
      position: absolute;
      inset: 0;
      z-index: 0;
      display: grid;
      grid-template-columns: repeat(16, 1fr);
      grid-auto-rows: 1fr;
      opacity: 0.5;
    }
    :global(.gridmotif span) {
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    :global(.gridmotif span.live) {
      animation: cellpulse 6s ease-in-out infinite;
    }
    :global(.gridmotif span.sandlive) {
      animation: cellpulseSand 7s ease-in-out infinite;
    }
    @keyframes cellpulse {
      0%,
      100% {
        background: transparent;
      }
      50% {
        background: rgba(90, 44, 102, 0.4);
      }
    }
    @keyframes cellpulseSand {
      0%,
      100% {
        background: transparent;
      }
      50% {
        background: rgba(232, 213, 176, 0.28);
      }
    }

    /* ---- Scroll reveal ---- */
    .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 0.6s ease,
        transform 0.6s ease;
    }
    .reveal.in {
      opacity: 1;
      transform: none;
    }

