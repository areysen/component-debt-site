    /* ---- Hero grid motif and reveal: must be global, the spans are
       created at runtime and never receive Astro's scope hash ---- */
    :global(.gridmotif) {
      position: absolute;
      inset: 0;
      z-index: 0;
      display: grid;
      grid-template-columns: repeat(16, 1fr);
      grid-auto-rows: 1fr;
      opacity: 0.5;
    }
    :global(.gridmotif span) {
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    :global(.gridmotif span.live) {
      animation: cellpulse 6s ease-in-out infinite;
    }
    :global(.gridmotif span.sandlive) {
      animation: cellpulseSand 7s ease-in-out infinite;
    }
    @keyframes cellpulse {
      0%,
      100% {
        background: transparent;
      }
      50% {
        background: rgba(90, 44, 102, 0.4);
      }
    }
    @keyframes cellpulseSand {
      0%,
      100% {
        background: transparent;
      }
      50% {
        background: rgba(224, 122, 95, 0.28);
      }
    }

    /* ---- Scroll reveal ----
       Progressive enhancement: content is visible by default. The hidden
       starting state only applies once the inline script has set html.js, so
       a visitor without JS (or before JS runs) always sees the content. The
       gated selectors below outrank .reveal.in, so .in must also be gated. */
    :global(html.js) .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 0.6s ease,
        transform 0.6s ease;
    }
    :global(html.js) .reveal.in {
      opacity: 1;
      transform: none;
    }

